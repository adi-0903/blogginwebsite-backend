# Email Configuration
# Gmail Example (requires App Password if 2FA is enabled):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@mindmatrix.com

# SendGrid Example:
# EMAIL_BACKEND=sendgrid_backend.SendgridBackend
# SENDGRID_API_KEY=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@mindmatrix.com

# Mailgun Example:
# EMAIL_BACKEND=django_mailgun.MailgunBackend
# MAILGUN_ACCESS_KEY=your-mailgun-api-key
# MAILGUN_SERVER_NAME=your-domain.mailgun.org
# DEFAULT_FROM_EMAIL=noreply@mindmatrix.com

# Development (Console Backend - prints to console):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@mindmatrix.com

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173
